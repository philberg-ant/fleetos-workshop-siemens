{
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Bash(curl *localhost:8001*)",
      "Bash(python3 checks/*)",
      "Bash(python3 -m http.server*)",
      "Bash(mv inbox/*)",
      "Bash(mv ./inbox/*)",
      "Bash(date*)",
      "Read",
      "Grep",
      "Glob",
      "Edit",
      "Write"
    ],
    "deny": [
      "WebFetch",
      "WebSearch"
    ],
    "additionalDirectories": [
      "../dashboard"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard_sim.py\" || python \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard_sim.py\" || true"
          }
        ]
      }
    ]
  }
}
